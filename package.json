{
  "private": true,
  "name": "@earth-app/sky",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "generate": "nuxt build",
    "generate:ios": "nuxt build --dotenv .env.ios",
    "generate:android": "nuxt build --dotenv .env.android",
    "build:ios": "bun run generate:ios && bunx cap sync ios && bunx cap build ios",
    "build:android": "bun run generate:android && bunx cap sync android && bunx cap build android",
    "dev": "bunx nuxi dev --dotenv .config/local.env --no-restart --public --port 3001",
    "dev:remote": "bunx nuxi dev --dotenv .config/production.env --no-restart --public --port 3001",
    "dev:remote:android": "bun run dev:remote -- --dotenv .env.android",
    "dev:remote:ios": "bun run dev:remote -- --dotenv .env.ios",
    "dev:android": "bash scripts/dev-android.sh",
    "dev:ios": "bash scripts/dev-ios.sh",
    "sync": "bunx cap sync",
    "sync:assets": "bun run capacitor-assets generate --ios --android && bash scripts/generate-ios-icon-variants.sh",
    "prettier": "bunx prettier --write .",
    "prettier:check": "bunx prettier --check .",
    "postinstall": "nuxt prepare",
    "prepare": "husky install"
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/barcode-scanner": "^3.0.2",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/dialog": "^8.0.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/motion": "^8.0.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capacitor/toast": "^8.0.1",
    "@capgo/capacitor-audio-recorder": "^8.2.1",
    "@capgo/capacitor-pedometer": "^8.0.32",
    "@codecov/nuxt-plugin": "^2.0.1",
    "@earth-app/crust": "0.4.0-589b69c",
    "@earth-app/ocean": "1.0.1",
    "@ionic/pwa-elements": "^3.4.0",
    "@ionic/vue": "8.8.1",
    "@ionic/vue-router": "8.8.1",
    "@nuxt/icon": "^2.2.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.8.1",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/i18n": "^10.4.0",
    "@nuxtjs/ionic": "^1.0.2",
    "@tiptap/extension-drag-handle": "^3.23.6",
    "@types/luxon": "^3.7.1",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "luxon": "^3.7.2",
    "nuxt": "^4.4.6",
    "nuxt-viewport": "^2.4.0",
    "piexifjs": "^1.0.6",
    "vue": "^3.5.35"
  },
  "overrides": {
    "@ionic/core": "8.8.1",
    "@ionic/vue": "8.8.1",
    "@ionic/vue-router": "8.8.1"
  },
  "patchedDependencies": {
    "@capacitor-community/apple-sign-in@7.1.0": "patches/@capacitor-community%2Fapple-sign-in@7.1.0.patch"
  },
  "devDependencies": {
    "@capacitor/cli": "8.1.0",
    "@iconify-json/line-md": "^1.2.16",
    "@iconify-json/logos": "^1.2.11",
    "@ionic/cli": "^7.2.1",
    "@prettier/plugin-xml": "^3.4.2",
    "@types/piexifjs": "^1.0.0",
    "@vue/cli-service": "5.0.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "vue-tsc": "^3.3.2"
  },
  "lint-staged": {
    "*.{ts,vue,css,md,json,xml,plist,storyboard,yml}": "prettier --write"
  }
}
