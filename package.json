{
  "private": true,
  "name": "@earth-app/sky",
  "version": "1.0.2",
  "type": "module",
  "scripts": {
    "generate": "NODE_OPTIONS='--max-old-space-size=8192' nuxt build",
    "generate:ios": "NODE_OPTIONS='--max-old-space-size=8192' nuxt build --dotenv .env.ios",
    "generate:android": "NODE_OPTIONS='--max-old-space-size=8192' nuxt build --dotenv .env.android",
    "build:ios": "bun run generate:ios && bun run sync:version && bunx cap sync ios && bunx cap build ios",
    "build:android": "bun run generate:android && bun run sync:version && bunx cap sync android && bunx cap build android",
    "dev": "bunx nuxi dev --dotenv .config/local.env --no-restart --public --port 3001",
    "dev:remote": "bunx nuxi dev --dotenv .config/production.env --no-restart --public --port 3001",
    "dev:remote:android": "bun run dev:remote -- --dotenv .env.android",
    "dev:remote:ios": "bun run dev:remote -- --dotenv .env.ios",
    "dev:android": "bash scripts/dev-android.sh",
    "dev:ios": "bash scripts/dev-ios.sh",
    "sync": "bunx cap sync",
    "sync:version": "bun run scripts/sync-version.ts",
    "sync:assets": "bun run capacitor-assets generate --ios --android && bash scripts/generate-ios-icon-variants.sh && bash scripts/generate-watch-icon.sh",
    "prettier": "bunx prettier --write .",
    "prettier:check": "bunx prettier --check .",
    "postinstall": "nuxt prepare",
    "prepare": "husky install",
    "dev:test": "NUXT_PUBLIC_TEST_BUILD=1 NUXT_PUBLIC_CLOUD_BASE_URL=${NUXT_PUBLIC_CLOUD_BASE_URL:-http://127.0.0.1:9898} NUXT_PUBLIC_CRUST_BASE_URL=${NUXT_PUBLIC_CRUST_BASE_URL:-http://127.0.0.1:8787} bunx nuxi dev --dotenv .config/local.env --no-restart --port ${SKY_PORT:-3001} --host 127.0.0.1",
    "build:test": "NUXT_PUBLIC_TEST_BUILD=1 NUXT_PUBLIC_API_BASE_URL=${NUXT_PUBLIC_API_BASE_URL:-http://127.0.0.1:8787} NUXT_PUBLIC_CLOUD_BASE_URL=${NUXT_PUBLIC_CLOUD_BASE_URL:-http://127.0.0.1:9898} NUXT_PUBLIC_CRUST_BASE_URL=${NUXT_PUBLIC_CRUST_BASE_URL:-http://127.0.0.1:8787} NODE_OPTIONS='--max-old-space-size=8192' bunx nuxi build --dotenv .config/local.env",
    "build:e2e": "NUXT_PUBLIC_TEST_BUILD=1 NUXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8788 NUXT_PUBLIC_CRUST_BASE_URL=http://127.0.0.1:8788 NUXT_PUBLIC_CLOUD_BASE_URL=http://127.0.0.1:9899 NODE_OPTIONS='--max-old-space-size=8192' bunx nuxi build --dotenv .config/local.env",
    "serve:test": "PORT=${SKY_PORT:-3001} HOST=127.0.0.1 bun tests/e2e/utils/static-server.ts",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "SKY_PORT=3002 MOCK_MANTLE_PORT=8788 MOCK_CLOUD_PORT=9899 NUXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8788 NUXT_PUBLIC_CRUST_BASE_URL=http://127.0.0.1:8788 NUXT_PUBLIC_CLOUD_BASE_URL=http://127.0.0.1:9899 PLAYWRIGHT_BASE_URL=http://127.0.0.1:3002 PLAYWRIGHT_PROD=1 playwright test --project=chromium --project=mobile-chromium",
    "test:e2e:coverage": "SKY_PORT=3002 MOCK_MANTLE_PORT=8788 MOCK_CLOUD_PORT=9899 NUXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8788 NUXT_PUBLIC_CRUST_BASE_URL=http://127.0.0.1:8788 NUXT_PUBLIC_CLOUD_BASE_URL=http://127.0.0.1:9899 PLAYWRIGHT_BASE_URL=http://127.0.0.1:3002 PLAYWRIGHT_PROD=1 COVERAGE=1 playwright test --project=chromium --project=mobile-chromium",
    "test:e2e:integration": "PLAYWRIGHT_PROD=1 MOCK_DISABLED=1 playwright test --project=chromium --project=mobile-chromium",
    "test:e2e:webkit": "SKY_PORT=3002 MOCK_MANTLE_PORT=8788 MOCK_CLOUD_PORT=9899 NUXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8788 NUXT_PUBLIC_CRUST_BASE_URL=http://127.0.0.1:8788 NUXT_PUBLIC_CLOUD_BASE_URL=http://127.0.0.1:9899 PLAYWRIGHT_BASE_URL=http://127.0.0.1:3002 PLAYWRIGHT_PROD=1 playwright test --project=webkit",
    "test:e2e:report": "playwright show-report playwright-report",
    "test:coverage:report": "bun tests/e2e/utils/coverage.ts",
    "test:mock-server": "bun tests/e2e/utils/mock-server.ts",
    "typecheck": "bunx vue-tsc --noEmit"
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/barcode-scanner": "^3.0.2",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/dialog": "^8.0.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/motion": "^8.0.0",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capacitor/toast": "^8.0.1",
    "@capgo/capacitor-audio-recorder": "^8.2.5",
    "@capgo/capacitor-pedometer": "^8.0.37",
    "@capgo/capacitor-watch": "^8.1.0",
    "@codecov/nuxt-plugin": "^2.0.1",
    "@earth-app/crust": "0.5.1",
    "@earth-app/ocean": "1.1.0",
    "@ionic/pwa-elements": "^3.4.0",
    "@ionic/vue": "8.8.13",
    "@ionic/vue-router": "8.8.13",
    "@nuxt/icon": "^2.3.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.9.0",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/i18n": "^10.4.0",
    "@nuxtjs/ionic": "^1.0.2",
    "@tensorflow/tfjs": "^4.22.0",
    "@tiptap/extension-drag-handle": "^3.27.3",
    "@types/luxon": "^3.7.2",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "html5-qrcode": "^2.3.8",
    "luxon": "^3.7.2",
    "nsfwjs": "^4.3.0",
    "nuxt": "^4.4.8",
    "nuxt-viewport": "^2.4.0",
    "obscenity": "^0.4.6",
    "piexifjs": "^1.0.6",
    "tesseract.js": "^7.0.0",
    "vue": "^3.5.39"
  },
  "overrides": {
    "@ionic/core": "8.8.13",
    "@ionic/vue": "8.8.13",
    "@ionic/vue-router": "8.8.13"
  },
  "patchedDependencies": {
    "@capacitor-community/apple-sign-in@7.1.0": "patches/@capacitor-community%2Fapple-sign-in@7.1.0.patch",
    "@capgo/capacitor-pedometer@8.0.32": "patches/@capgo%2Fcapacitor-pedometer@8.0.32.patch"
  },
  "devDependencies": {
    "@capacitor/cli": "8.4.1",
    "@iconify-json/line-md": "^1.2.16",
    "@iconify-json/logos": "^1.2.11",
    "@ionic/cli": "^7.2.1",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.61.1",
    "@prettier/plugin-xml": "^3.4.2",
    "@types/bun": "^1.3.14",
    "@types/piexifjs": "^1.0.0",
    "@vitest/coverage-v8": "4.1.9",
    "@vue/cli-service": "5.0.9",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "v8-to-istanbul": "^9.3.0",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.6"
  },
  "lint-staged": {
    "*.{ts,vue,css,md,json,xml,plist,storyboard,yml}": "prettier --write"
  }
}
