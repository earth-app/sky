<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
	"http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>The Earth App</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.earthapp.sky.oauth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.earthapp.sky</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>FirebaseAppDelegateProxyEnabled</key>
	<false />
	<key>ITSAppUsesNonExemptEncryption</key>
	<false />
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.lifestyle</string>
	<key>LSRequiresIPhoneOS</key>
	<true />
	<key>NSCameraUsageDescription</key>
	<string
		>The Earth App uses your camera so you can take photos to complete quest steps and attach images to events and articles you create — for example, snapping a photo of a landmark to prove you visited it.</string>
	<key>NSHealthShareUsageDescription</key>
	<string
		>The Earth App reads workout distance from Apple Health so your quest progress reflects what your Apple Watch already tracks.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string
		>The Earth App does not write or save any data to Apple Health; it only reads your workout distance to update your quest progress.</string>
	<key>NSHumanReadableCopyright</key>
	<string>Copyright (c) 2026 The Earth App</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string
		>The Earth App uses your location to verify where you complete a quest step and to tag the location of photos you submit — for example, confirming you were at a local park for an outdoor quest.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string
		>The Earth App uses your microphone to record short audio clips for quest steps that ask you to speak or capture sound — for example, recording a voice note describing what you discovered.</string>
	<key>NSMotionUsageDescription</key>
	<string
		>The Earth App uses motion and fitness data to count your steps and measure distance for movement-based quest steps — for example, verifying you walked the distance a quest requires.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string
		>The Earth App accesses your photo library so you can choose existing photos to attach to events and articles you create — for example, selecting a saved photo of a place to feature in an event.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIApplicationShortcutItems</key>
	<array>
		<dict>
			<key>UIApplicationShortcutItemIconType</key>
			<string>UIApplicationShortcutIconTypeCompose</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Start a Quest</string>
			<key>UIApplicationShortcutItemType</key>
			<string>com.earthapp.sky.shortcut.quests</string>
			<key>UIApplicationShortcutItemUserInfo</key>
			<dict>
				<key>route</key>
				<string>/tabs/quests</string>
			</dict>
		</dict>
		<dict>
			<key>UIApplicationShortcutItemIconType</key>
			<string>UIApplicationShortcutIconTypeAlarm</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Notifications</string>
			<key>UIApplicationShortcutItemType</key>
			<string>com.earthapp.sky.shortcut.notifications</string>
			<key>UIApplicationShortcutItemUserInfo</key>
			<dict>
				<key>route</key>
				<string>/tabs/profile/notifications</string>
			</dict>
		</dict>
		<dict>
			<key>UIApplicationShortcutItemIconType</key>
			<string>UIApplicationShortcutIconTypeContact</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>My Profile</string>
			<key>UIApplicationShortcutItemType</key>
			<string>com.earthapp.sky.shortcut.profile</string>
			<key>UIApplicationShortcutItemUserInfo</key>
			<dict>
				<key>route</key>
				<string>/tabs/profile/editor</string>
			</dict>
		</dict>
	</array>
	<key>UIUserInterfaceStyle</key>
	<string>Automatic</string>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true />
</dict>
</plist>
