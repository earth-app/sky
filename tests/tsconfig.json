{
	"extends": "../.nuxt/tsconfig.json",
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"allowImportingTsExtensions": false,
		"noEmit": true,
		"types": ["node", "@playwright/test", "@nuxt/test-utils"],
		"paths": {
			"~~/*": ["../*"],
			"@@/*": ["../*"],
			"~/*": ["../src/*"],
			"@/*": ["../src/*"],
			"types": ["../node_modules/@earth-app/crust/src/shared/types"],
			"types/*": ["../node_modules/@earth-app/crust/src/shared/types/*"],
			"utils": ["../node_modules/@earth-app/crust/src/shared/utils/util"],
			"schemas": ["../node_modules/@earth-app/crust/src/shared/utils/schemas"],
			"stores": ["../node_modules/@earth-app/crust/src/stores"],
			"stores/*": ["../node_modules/@earth-app/crust/src/stores/*"],
			"#test-utils/*": ["./e2e/utils/*"]
		}
	},
	"include": ["./**/*.ts", "./**/*.spec.ts"],
	"comment": "unit/ is typechecked + run by vitest (nuxt env); excluded here since this light config lacks Nuxt's ambient auto-imports",
	"exclude": ["../node_modules", "../.output", "../.nuxt", "../dist", "./unit"]
}
